# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — never expose to client
SUPABASE_DB_ENCRYPTION_KEY=       # for health-field encryption at rest

# Anthropic (Claude Haiku for chat, Sonnet for summaries/reports)
ANTHROPIC_API_KEY=

# ElevenLabs (conversational agent: STT + TTS + bundled LLM at launch)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# HeyGen LiveAvatar (Lite mode, Essential plan)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# Stripe (use test mode in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_WELLNESS_PROFILE=    # test-mode Price id for the $29 Wellness Profile (price_…)
WELLNESS_PROFILE_CREDITS=12       # credits granted per Wellness Profile purchase
WELLNESS_PROFILE_PRICE_CENTS=2900 # price in cents (for unit_price_cents = round(price/credits))

# Affiliate (RevOffers — Ava only; CrakRevenue is Lux/Phase 3)
REVOFFERS_AFFILIATE_ID=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
GEO_BLOCK_STATES=CA,NY
FREE_DAILY_MESSAGE_CAP=10          # free-tier text messages per day (soft funnel cap)
CREDIT_EXPIRY_MONTHS=12            # confirm legal period per state before launch
APP_SUNSET_MODE=false             # true blocks new spend, allows refunds + data deletion
COMPLIANCE_LOG_SALT=               # HMAC salt for de-identified compliance_log user_ref
