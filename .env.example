# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Brand variant: "ava" or "lux"
NEXT_PUBLIC_BRAND=ava

# Phase 2 — live avatar (Simli)
NEXT_PUBLIC_SIMLI_API_KEY=

# MVP shortcut only — direct Claude calls from the browser.
# Remove before production. Backend should proxy these.
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# Waitlist capture endpoint for geo-blocked states (NY, CA).
# Optional. If unset, captures only log to dev console (no persistence).
# Once the backend ships, point at /waitlist on the HIPAA-aligned API.
# Until then a Mailchimp / ConvertKit / Vercel KV no-PHI endpoint works.
NEXT_PUBLIC_WAITLIST_URL=
